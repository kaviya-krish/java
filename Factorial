import java.util.*;
public class Main{
    public static int fact(int n)
    {
        int fact=1;
        if(n==0)
        {
            return 1;
        }
        for(int i=1;i<=n;i++)
        {
            fact=fact*i;
        }
        return fact;
    }
    public static void main(String []args)
    {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int res=fact(n);
        System.out.println(res);
    }
}
