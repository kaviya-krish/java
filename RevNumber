import java.util.*;
public class main{
    public static int revNum(int n)
    {
        int temp=n;
        int rev=0;
        while(n!=0)
        {
            int l=n%10;
            rev=(rev*10)+l;
            n=n/10;
        }
        return rev;
    }
    public static void main(String[] args)
    {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int ans=revNum(n);
        System.out.println(ans);
    }
}
