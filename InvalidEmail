import java.util.*;

public class Main {

    public static List<String> findInvalidEmails(List<String> emails) {
        List<String> invalid = new ArrayList<>();

        for(String email : emails) {
            int at = email.indexOf('@');
            int dot = email.lastIndexOf('.'); 

            if(at == -1 || dot == -1 || dot < at) {
                invalid.add(email);
            }
        }

        return invalid;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of emails: ");
        int n = sc.nextInt();
        sc.nextLine(); 

        List<String> emails = new ArrayList<>();

        for(int i = 0; i < n; i++) {
            System.out.print("Enter email " + (i + 1) + ": ");
            String email = sc.nextLine();
            emails.add(email);
        }

        List<String> invalidEmails = findInvalidEmails(emails);

        System.out.println("\nInvalid Emails:");
        for(String email : invalidEmails) {
            System.out.println(email);
        }

    }
}
